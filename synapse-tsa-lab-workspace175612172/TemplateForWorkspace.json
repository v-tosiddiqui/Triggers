			"name": "[concat(parameters('workspaceName'), '/Notebook HelloWorld')]",
			"type": "Microsoft.Synapse/workspaces/notebooks",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"nbformat": 4,
				"nbformat_minor": 2,
				"bigDataPool": {
					"referenceName": "ASparkpool",
					"type": "BigDataPoolReference"
				},
				"sessionProperties": {
