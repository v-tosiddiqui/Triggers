			"apiVersion": "2019-06-01-preview",
			"properties": {
				"activities": [
					{
						"name": "PrintHelloWorld",
						"type": "SynapseNotebook",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
