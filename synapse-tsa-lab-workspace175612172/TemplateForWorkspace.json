							"referenceName": "synapse-tsa-lab-workspace175612172-WorkspaceDefaultSqlServer",
							"type": "LinkedServiceReference",
							"parameters": {
								"DBName": "master"
							}
						},
						"typeProperties": {
							"scripts": [
								{
									"type": "Query",
									"text": "select @@version ;"
								}
